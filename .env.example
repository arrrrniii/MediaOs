# ═══════════════════════════════════════
#  MediaOS Configuration
# ═══════════════════════════════════════

# ── PostgreSQL ──────────────────────
PG_DATABASE=mediaos
PG_USER=mediaos
PG_PASSWORD=changeme_pg_password

# ── MinIO ───────────────────────────
MINIO_ROOT_USER=mvadmin
MINIO_ROOT_PASSWORD=changeme_minio_password
MINIO_BUCKET=mediaos

# ── Redis ───────────────────────────
REDIS_PASSWORD=changeme_redis_password

# ── API Worker ──────────────────────
API_PORT=3000
PUBLIC_URL=http://localhost:3000
NODE_ENV=production

# Master admin key — REQUIRED for account/project management
# Generate with: node -e "console.log('mv_master_' + require('crypto').randomBytes(24).toString('hex'))"
MASTER_KEY=mv_master_your_secret_here

# ── Initial Admin Account ─────────
# Created automatically on first boot if no accounts exist.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password

# ── Image Processing ────────────────
WEBP_QUALITY=80
MAX_WIDTH=1600
MAX_HEIGHT=1600

# ── Video Processing ────────────────
VIDEO_CRF=20
VIDEO_MAX_HEIGHT=1080
CONCURRENCY=3

# ── Limits ──────────────────────────
MAX_FILE_SIZE=104857600   # 100MB

# ── Dashboard ───────────────────────
# Set COMPOSE_PROFILES=dashboard to enable the admin panel (enabled by default)
# Remove or leave empty to run API-only without the dashboard
COMPOSE_PROFILES=dashboard
DASHBOARD_PORT=3001
DASHBOARD_URL=http://localhost:3001
NEXTAUTH_SECRET=changeme_nextauth_secret
